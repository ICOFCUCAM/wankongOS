# --- AI providers (all optional) -------------------------------------------
# When a key is present, employees pinned to that provider use it. With no keys,
# the platform runs fully on the built-in hermetic `local` provider.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
# Provider used when an employee doesn't pin one (anthropic|openai|google|local).
DEFAULT_AI_PROVIDER=local

# --- API --------------------------------------------------------------------
PORT=4000

# --- Web --------------------------------------------------------------------
# The API is embedded in the web app and served at /api — no configuration
# needed. Set this only to point the console at an external API deployment.
# NEXT_PUBLIC_API_URL=https://api.example.com

# --- Production data layer (see packages/store/schema.sql) ------------------
# The reference store is in-memory. To back it with Postgres/Supabase, wire a
# repository implementation against this connection string.
DATABASE_URL=
